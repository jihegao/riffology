# Server-side only. Never expose this value to the browser.
# Configure the local OpenCode provider to consume this key; never commit .env.
OPENCODE_API_KEY=
# Verify the model identifier against the locally configured OpenCode provider at startup.
OPENCODE_MODEL=
# Loopback URL of an already running local OpenCode server (for example http://127.0.0.1:4096).
OPENCODE_URL=
# Comma-separated provider IDs allowed for this demo (for example deepseek).
OPENCODE_ALLOWED_PROVIDERS=
# Optional basic authentication for the local OpenCode server.
OPENCODE_SERVER_USERNAME=
OPENCODE_SERVER_PASSWORD=
# Keep true for the deterministic local demo; set false only for configured live OpenCode verification.
RIFF_SKIP_OPENCODE=true
