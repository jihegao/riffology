{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "riff://wind-turbine-maintenance/parameter-schema/v1",
  "title": "Wind turbine maintenance parameters",
  "type": "object",
  "additionalProperties": false,
  "required": ["turbine_count", "crew_count", "maintenance_period_days", "normal_failure_rate_per_day", "repair_low_hours", "repair_mode_hours", "repair_high_hours", "maintenance_low_hours", "maintenance_mode_hours", "maintenance_high_hours", "replacement_low_hours", "replacement_mode_hours", "replacement_high_hours", "major_replacement_enabled", "major_replacement_probability", "farm_width_km", "farm_height_km", "depot_x_km", "depot_y_km", "crew_speed_km_per_hour", "daily_revenue_per_operating_turbine", "crew_cost_per_day", "repair_cost", "maintenance_cost", "replacement_cost", "minimum_availability_fraction"],
  "properties": {
    "turbine_count": {"type": "integer", "minimum": 1, "maximum": 500, "unit": "count"},
    "crew_count": {"type": "integer", "minimum": 1, "maximum": 50, "unit": "count"},
    "maintenance_period_days": {"type": "number", "minimum": 1, "maximum": 3650, "unit": "day"},
    "normal_failure_rate_per_day": {"type": "number", "minimum": 0.000001, "maximum": 10, "unit": "1/day"},
    "repair_low_hours": {"type": "number", "minimum": 0.01, "maximum": 720, "unit": "hour"},
    "repair_mode_hours": {"type": "number", "minimum": 0.01, "maximum": 720, "unit": "hour"},
    "repair_high_hours": {"type": "number", "minimum": 0.01, "maximum": 720, "unit": "hour"},
    "maintenance_low_hours": {"type": "number", "minimum": 0.01, "maximum": 720, "unit": "hour"},
    "maintenance_mode_hours": {"type": "number", "minimum": 0.01, "maximum": 720, "unit": "hour"},
    "maintenance_high_hours": {"type": "number", "minimum": 0.01, "maximum": 720, "unit": "hour"},
    "replacement_low_hours": {"type": "number", "minimum": 0.01, "maximum": 720, "unit": "hour"},
    "replacement_mode_hours": {"type": "number", "minimum": 0.01, "maximum": 720, "unit": "hour"},
    "replacement_high_hours": {"type": "number", "minimum": 0.01, "maximum": 720, "unit": "hour"},
    "major_replacement_enabled": {"type": "boolean"},
    "major_replacement_probability": {"type": "number", "minimum": 0, "maximum": 1, "unit": "fraction"},
    "farm_width_km": {"type": "number", "minimum": 0.1, "maximum": 100, "unit": "km"},
    "farm_height_km": {"type": "number", "minimum": 0.1, "maximum": 100, "unit": "km"},
    "depot_x_km": {"type": "number", "minimum": 0, "maximum": 100, "unit": "km"},
    "depot_y_km": {"type": "number", "minimum": 0, "maximum": 100, "unit": "km"},
    "crew_speed_km_per_hour": {"type": "number", "minimum": 0.1, "maximum": 200, "unit": "km/hour"},
    "daily_revenue_per_operating_turbine": {"type": "number", "minimum": 0, "maximum": 1000000000, "unit": "synthetic_currency/day"},
    "crew_cost_per_day": {"type": "number", "minimum": 0, "maximum": 1000000000, "unit": "synthetic_currency/day"},
    "repair_cost": {"type": "number", "minimum": 0, "maximum": 1000000000, "unit": "synthetic_currency/operation"},
    "maintenance_cost": {"type": "number", "minimum": 0, "maximum": 1000000000, "unit": "synthetic_currency/operation"},
    "replacement_cost": {"type": "number", "minimum": 0, "maximum": 1000000000, "unit": "synthetic_currency/operation"},
    "minimum_availability_fraction": {"type": "number", "minimum": 0, "maximum": 1, "unit": "fraction"}
  }
}
